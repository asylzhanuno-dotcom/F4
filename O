local function IsInLobbyZone(player)
	local char = player.Character
	local hrp = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return true end 
	
	local regularLobby = Workspace:FindFirstChild("RegularLobby")
	if regularLobby then
		local pPos = hrp.Position
		for _, part in ipairs(regularLobby:GetDescendants()) do
			if part:IsA("BasePart") then
				local bounds = part.Size / 2
				local cframe = part.CFrame
				local localPos = cframe:PointToObjectSpace(pPos)
				if math.abs(localPos.X) <= bounds.X + 5 and 
				   math.abs(localPos.Y) <= bounds.Y + 8 and 
				   math.abs(localPos.Z) <= bounds.Z + 5 then
					return true
				end
			end
		end
	end
	return false
end

local function CheckWallVisibility(targetPart)
	if IgnoreWallsEnabled then return true end
	if not LocalPlayer.Character or not targetPart then return false end
	local Cam = Workspace.CurrentCamera or Workspace:FindFirstChildOfClass("Camera")
	local origin = Cam.CFrame.Position
	local direction = targetPart.Position - origin
	local raycastParams = RaycastParams.new()
	raycastParams.FilterInstanceTokens = {LocalPlayer.Character}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	local raycastResult = Workspace:Raycast(origin, direction, raycastParams)
	if raycastResult then return raycastResult.Instance:IsDescendantOf(targetPart.Parent) end
	return true
end

