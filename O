-- Генерация градиентного текста
local function CreateGradientText(text, colorStart, colorEnd)
    local len = #text
    if len == 0 then return text end
    local result = ""
    for i = 1, len do
        local character = text:sub(i, i)
        local baseRatio = (i - 1) / (len - 1 == 0 and 1 or len - 1)
        local ratio = math.pow(baseRatio, 3)
        local r = colorStart.R + (colorEnd.R - colorStart.R) * ratio
        local g = colorStart.G + (colorEnd.G - colorStart.G) * ratio
        local b = colorStart.B + (colorEnd.B - colorStart.B) * ratio
        result = result .. string.format('<font color="rgb(%d,%d,%d)">%s</font>', math.round(r * 255), math.round(g * 255), math.round(b * 255), character)
    end
    return "<b>" .. result .. "</b>"
end

local function GetOnlineImage(url)
    if writefile and game.HttpGet then
        local fileName = "custom_bg_" .. string.match(url, "([^/]+)$")
        if not isfile(fileName) then
            local success, content = pcall(function() return game:HttpGet(url) end)
            if success and content then writefile(fileName, content) end
        end
        if isfile(fileName) and getcustomasset then return getcustomasset(fileName) end
    end
    return url
end

