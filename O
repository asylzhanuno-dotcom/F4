local function AttractGun(gunPart)
	if gunPart and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
		if HasKnife(LocalPlayer) or HasGun(LocalPlayer) then return end
		task.spawn(function()
			IsFetching = true
			local hrp = LocalPlayer.Character.HumanoidRootPart
			while IsFetching and gunPart.Parent and not HasGun(LocalPlayer) do
				gunPart.CanCollide = false
				gunPart.CFrame = hrp.CFrame + Vector3.new(0, 1, 0)
				if firetouchinterest then
					firetouchinterest(gunPart, hrp, 0) task.wait(0.005) firetouchinterest(gunPart, hrp, 1)
				else task.wait(0.01) end
			end
			IsFetching = false
		end)
	end
end

