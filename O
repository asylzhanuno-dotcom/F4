local RoseIconColor = Color3.fromHex("#882D47")
local function CleanUIStyle(mainUI)
	pcall(function()
		for _, v in ipairs(mainUI:GetDescendants()) do
			if v:IsA("ScrollingFrame") or v.Name == "Content" or v.Name == "Container" then v.BackgroundTransparency = 1 end
			if v:IsA("Frame") or v:IsA("TextButton") then
				if v.Name == "Button" or v.Name == "Option" or v.Name == "Toggle" or v.Name == "Base" or v.Name == "Holder" or v.Name:find("Section") then
					if v.Name ~= "Background" and v.Name ~= "BackgroundImage" then
						v.BackgroundColor3 = Color3.fromHex("#4A1425")
						v.BackgroundTransparency = 0.25
					end
				end
			end
			if v:IsA("TextLabel") or v:IsA("TextBox") then
				if not v.Text:find("<font color=") then v.TextColor3 = Color3.fromHex("#FFB3C6") end
				v.TextTransparency = 0 
			elseif v:IsA("ImageLabel") and v.Name ~= "Background" and v.Name ~= "BackgroundImage" then
				v.ImageColor3 = RoseIconColor
				v.ImageTransparency = 0
			elseif v:IsA("UIStroke") then
				v.Color = Color3.fromHex("#882D47")
			end
		end
	end)
end

