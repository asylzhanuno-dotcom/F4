-- ИСПРАВЛЕННОЕ ОПРЕДЕЛЕНИЕ РОЛИ (ПОДХВАТЫВАЕТ ВСЕХ ПОДОБРАВШИХ В ТЕЧЕНИЕ РАУНДА)
local function GetPlayerRole(player)
	if not player or not player.Parent then return "Lobby" end
	if DeadPlayersThisRound[player.Name] then return "Lobby" end
	local char = player.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	
	if RoundActive and (not char or not char:FindFirstChild("HumanoidRootPart") or (hum and hum.Health <= 0)) then
		if not IsInLobbyZone(player) then
			DeadPlayersThisRound[player.Name] = true
			return "Lobby"
		end
	end

	-- Прямой чекинг инвентаря на ходу
	if HasKnife(player) then return "Murderer" end
	if HasGun(player) then
		local initialRole = ServerLogRoles[player.Name]
		if initialRole == "Sheriff" then
			return "Sheriff"
		else
			return "Hero" -- Любой кто подобрал пест кроме исходного Шерифа получает статус Героя (Фиолетовый)
		end
	end

	local serverRole = ServerLogRoles[player.Name]
	if serverRole and serverRole ~= "Sheriff" then return serverRole end
	if not RoundActive or IsInLobbyZone(player) then return "Lobby" end
	return "Innocent"
end

