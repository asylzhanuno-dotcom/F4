-- // SILENT AIM & AIMBOT MECHANICS
local function GetMurderer()
	for _, p in ipairs(Players:GetPlayers()) do 
		if GetPlayerRole(p) == "Murderer" then return p end 
	end
	return nil
end

local function FireInstantHit()
	local murderer = GetMurderer()
	if not murderer or not murderer.Character then return end
	
	local targetPart = murderer.Character:FindFirstChild("Head")
	local gun = GetEquippedGun()
	local localHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	local Cam = Workspace.CurrentCamera or Workspace:FindFirstChildOfClass("Camera")
	
	if targetPart and gun and localHrp and Cam then
		if not CheckWallVisibility(targetPart) then return end
		
		local distance = (targetPart.Position - localHrp.Position).Magnitude
		local ping = Stats.Network.ServerGitLimitRoundTripTime:GetValue() or 0.04
		
		local targetVelocity = targetPart.Velocity
		local speedMod = math.clamp(targetVelocity.Magnitude, 0, 16)
		
		local predictedPosition = targetPart.Position
		if distance > 15 and speedMod > 2 then
			local offset = targetVelocity.Unit * (speedMod * ping * 0.95)
			predictedPosition = targetPart.Position + offset
		end
		
		TargetHeadPosition = predictedPosition
		
		Cam.CFrame = CFrame.lookAt(Cam.CFrame.Position, predictedPosition)
		localHrp.CFrame = CFrame.new(localHrp.Position, Vector3.new(predictedPosition.X, localHrp.Position.Y, predictedPosition.Z))
		
		gun:Activate()
		
		local shootRemote = UpdateShootRemote()
		local gunHandle = gun:FindFirstChild("Handle") or gun:FindFirstChildWhichIsA("BasePart")
		if shootRemote and gunHandle then
			local originCFrame = CFrame.lookAt(gunHandle.Position, predictedPosition)
			local targetCFrame = CFrame.new(predictedPosition)
			shootRemote:FireServer(originCFrame, targetCFrame)
		end
		
		task.delay(0.015, function()
			TargetHeadPosition = nil
		end)
	end
end

local OldIndex = nil
OldIndex = hookmetamethod(game, "__index", function(self, key)
	if not checkcaller() then
		if TargetHeadPosition and self == LocalPlayer:GetMouse() then
			if key == "Hit" then
				return CFrame.new(TargetHeadPosition)
			elseif key == "Target" then
				local murderer = GetMurderer()
				return murderer and murderer.Character and murderer.Character:FindFirstChild("Head") or nil
			end
		end
	end
	return OldIndex(self, key)
end)

local OldNamecall = nil
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
	local method = getnamecallmethod()
	local args = {...}
	
	if not checkcaller() and TargetHeadPosition then
		if self == Workspace and (method == "Raycast" or method == "raycast") then
			local murderer = GetMurderer()
			if murderer and murderer.Character and murderer.Character:FindFirstChild("Head") then
				local origin = args[1]
				local direction = (TargetHeadPosition - origin).Unit * 1000
				args[2] = direction
				return OldNamecall(self, table.unpack(args))
			end
		end
	end
	return OldNamecall(self, ...)
end)

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end 
	if (AutoAimEnabled or IdealWallbangEnabled) and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
		if GetEquippedGun() then task.spawn(FireInstantHit) end
	end
end)

RunService.RenderStepped:Connect(function()
	if not AutoAimEnabled or not GetEquippedGun() then return end
	local murderer = GetMurderer()
	if murderer and murderer.Character then
		local targetPart = murderer.Character:FindFirstChild("Head")
		local Cam = Workspace.CurrentCamera or Workspace:FindFirstChildOfClass("Camera")
		local localHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
		
		if targetPart and Cam and localHrp then 
			Cam.CFrame = CFrame.lookAt(Cam.CFrame.Position, targetPart.Position) 
			localHrp.CFrame = CFrame.new(localHrp.Position, Vector3.new(targetPart.Position.X, localHrp.Position.Y, targetPart.Position.Z))
		end
	end
end)

