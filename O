	for _, player in ipairs(Players:GetPlayers()) do
		if player == LocalPlayer then continue end
		local r = GetPlayerRole(player)
		local char = player.Character
		if r == "Lobby" or not char or not char:FindFirstChild("HumanoidRootPart") then
			if Highlights[player] then pcall(function() Highlights[player]:Destroy() end) Highlights[player] = nil end
			continue
		end
		
		local isSheriffOrHero = (r == "Sheriff" or r == "Hero")
		local enabled = (r == "Murderer" and Flags.EspMurder) or (isSheriffOrHero and Flags.EspSheriff) or (r == "Innocent" and Flags.EspInnocent)
		
		if enabled then
			if Highlights[player] then
				Highlights[player].Parent = char
				Highlights[player].FillColor = Colors[r] or Colors.Innocent
			else
				local hl = Instance.new("Highlight", char)
				hl.FillColor = Colors[r] or Colors.Innocent
				hl.OutlineColor = Color3.fromRGB(255, 255, 255)
				hl.FillTransparency = 0.4
				hl.OutlineTransparency = 0.1
				Highlights[player] = hl
			end
		else
			if Highlights[player] then pcall(function() Highlights[player]:Destroy() end) Highlights[player] = nil end
		end
	end
end)
